# ── Supabase (se completan automáticamente al hacer deploy) ──────
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# ── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...          # o sk_test_... para pruebas
STRIPE_WEBHOOK_SECRET=whsec_...        # webhook de SUSCRIPCIONES (stripe-webhook)

# Price IDs de cada plan (crearlos en Stripe > Products)
STRIPE_PRICE_BASICO=price_...
STRIPE_PRICE_PROFESIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Stripe Connect (cobros paciente → psicólogo, "Forma B") ──────
# Comisión de la plataforma sobre cada sesión cobrada (application_fee). 3 = 3%
PLATFORM_FEE_PERCENT=3
# Secreto del webhook DEDICADO a Connect (stripe-connect-webhook).
# Es DISTINTO de STRIPE_WEBHOOK_SECRET: créalo como endpoint Connect en Stripe.
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# ── Resend (emails) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=citas@tu-dominio.com

# ── URL pública del frontend ─────────────────────────────────────
SITE_URL=https://tu-dominio.com
